# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================
# Email Configuration (Resend)
# ============================================
# Ücretsiz plan: 100 email/gün
# https://resend.com adresinden API key alın
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx

# ============================================
# Gmail IMAP Email Monitoring (Opsiyonel)
# ============================================
# Otomatik fatura içe aktarma için Gmail IMAP
# Başlangıçta devre dışı - ihtiyaç halinde aktif edin
GMAIL_ENABLED=false
GMAIL_IMAP_USER=your-email@gmail.com
GMAIL_IMAP_PASSWORD=your-app-password-here
GMAIL_CHECK_INTERVAL=300000

# ============================================
# AI Configuration (Opsiyonel)
# ============================================
# AI Uzman Danışman özelliği için Gemini API key
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================
# Telegram Notifications (Opsiyonel)
# ============================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================================
# Application Settings
# ============================================
NEXT_PUBLIC_APP_NAME="Kimyasal Takip Sistemi"
NEXT_PUBLIC_COMPANY_NAME="DENİZLİ RATEKS TEKSTİL"
